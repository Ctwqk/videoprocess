DEPLOY_MODE=shared

# Shared mode targets
VP_DATABASE_URL=postgresql+asyncpg://vp:vp_secret@host.docker.internal:5432/videoprocess
VP_REDIS_URL=redis://host.docker.internal:6380/0
VP_MINIO_ENDPOINT=host.docker.internal:9000
VP_WATCHDOG_URL=http://host.docker.internal:8000
# Override this if embedding-gateway lives on Mac3 instead of the main host.
VP_EMBEDDING_GATEWAY_URL=http://host.docker.internal:8080
VP_QDRANT_URL=http://host.docker.internal:6333
VP_LLM_BASE_URL=http://host.docker.internal:8000/v1
VP_XTTS_BASE_URL=http://host.docker.internal:8010
X_CDP_URL=http://127.0.0.1:18810
X_CDP_TARGET=x.com

# Standalone mode
# COMPOSE_PROFILES=standalone
# VP_DATABASE_URL=postgresql+asyncpg://vp:vp_secret@postgres:5432/videoprocess
# VP_REDIS_URL=redis://redis:6379/0
# VP_MINIO_ENDPOINT=minio:9000

VP_POSTGRES_PASSWORD=vp_secret
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
STORAGE_BACKEND=local
VIDEO_SCHEDULE_DEFAULT_STATE=OPEN
